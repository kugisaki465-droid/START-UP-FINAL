# Dependencies — never commit these
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment secrets — never commit
.env
backend/.env

# SQLite DB — regenerated by seed on deploy
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# NOTE: frontend/dist IS committed so Render can serve it
# without needing a separate frontend build step

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
*.log
npm-debug.log*
